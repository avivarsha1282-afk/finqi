rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Make sure users can only read and write their own documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow the same rule for subcollections like chat_history
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
